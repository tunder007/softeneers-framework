# Environment files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
!**/.env.example

# Dependencies
**/node_modules

# Build outputs
**/dist
**/.next
**/out
**/build

# Monorepo tooling
.turbo
**/.turbo
.pnpm-store

# npm-first: package-lock.json is the committed lockfile. pnpm still works
# locally (both PMs supported) but its lockfile is not committed.
pnpm-lock.yaml
**/pnpm-lock.yaml

# CLI build artifact: templates are bundled into the package at build time
/apps/cli/templates

# Benchmark raw machine outputs (regenerated on demand). PROJECT-BENCHMARK.md is
# the kept summary and PROJECT-BENCHMARK.html its committed human view.
benchmark.json
project-benchmark.json

# Tool-generated artifacts we don't track (regenerated on demand)
.cursor
.workspace-optimizer
apps/MANIFEST.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS / editor noise
.DS_Store
.idea
.vscode

.vercel
