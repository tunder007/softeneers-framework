{
  "name": "create-softeneers-app",
  "version": "0.2.1",
  "description": "Scaffold a new Softeneers Framework project: 5 templates (next-fullstack, express-api, hono-api, tanstack-start, minimal) with db/auth/docker toggles.",
  "type": "module",
  "bin": {
    "create-softeneers-app": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-templates.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "clean": "rm -rf dist templates",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "softeneers",
    "scaffold",
    "generator",
    "create-app"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "author": "Tudor Damian",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tunder007/monolith_demo.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/tunder007/monolith_demo#readme"
}
