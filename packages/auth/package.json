  },
  "dependencies": {
    "better-auth": "^1.6.0"
  },
  "author": "Tudor Damian",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tunder007/monolith_demo.git",
    "directory": "packages/auth"
  },
  "homepage": "https://github.com/tunder007/monolith_demo#readme",
  "publishConfig": {
    "access": "public"
  }
