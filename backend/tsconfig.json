{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["index.ts", "controller/**/*.ts", "models/**/*.ts", "routes/**/*.ts"],
  "exclude": ["dist", "node_modules", "src"]
}
